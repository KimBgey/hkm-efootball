rules_version = '2';

// Toutes les lectures/écritures passent par des API routes Next.js utilisant
// le SDK Admin (firebase-admin), qui bypass ces règles avec un compte de service.
// Aucun accès direct depuis le navigateur n'est nécessaire : tout est refusé ici.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
