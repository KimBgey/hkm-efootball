# --- Firebase Admin SDK (serveur, API routes) ---
# Depuis la console Firebase du projet existant : Paramètres du projet > Comptes de service > Générer une nouvelle clé privée
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Garder les \n littéraux (le code les convertit en retours à la ligne)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Firebase client SDK (uniquement pour le login admin, /admin/login) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# --- Cloudinary (upload photo joueur + capture de paiement) ---
# Depuis le dashboard Cloudinary (cloudinary.com/console) : Cloud name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Gmail SMTP (Nodemailer) ---
SMTP_USER=
# Mot de passe d'application Gmail (pas le mot de passe du compte)
SMTP_APP_PASSWORD=
SMTP_FROM="hkm eFootball Kings <ton-adresse@gmail.com>"

# --- Développement local avec les émulateurs Firebase (Firestore + Auth) ---
# Mettre à "true" pour lancer contre `firebase emulators:start` au lieu du vrai projet.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
